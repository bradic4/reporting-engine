# GamingDW Environment Variables

# Database Configuration
# Options: sqlite, postgres
DatabaseProvider=postgres
ConnectionStrings__PostgresConnection="Host=db;Database=gamingdw;Username=dwadmin;Password=YOUR_SECURE_DB_PASSWORD"

# Authentication
# This is the password for the initial 'admin' account
ADMIN_DEFAULT_PASSWORD="ChangeMeImmdiatley123!"

# Application Settings
UploadSettings__MaxFileSizeMB=20
CookieSettings__ExpireHours=8
